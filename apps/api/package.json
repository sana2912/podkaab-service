    "@podkaap/db": "workspace:*",
    "@podkaap/queue": "workspace:*",
    "@podkaap/shared": "workspace:*",
    "bullmq": "^5.72.1",
    "elysia": "^1.4.28"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "typescript": "^6.0.2"
  }
