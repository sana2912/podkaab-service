DATABASE_URL="postgresql://postgres:postgres@localhost:5432/podkaap?schema=public"
JWT_SECRET="your-secret-here"
PORT=3000
NODE_ENV="development"

# Storage
STORAGE_PROVIDER="cloudinary"   # or "s3"
CLOUDINARY_URL=""
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# S3-compatible (used when STORAGE_PROVIDER=s3)
S3_ENDPOINT=""
S3_BUCKET=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_REGION="us-east-1"

# DragonflyDB (Redis-compatible) — used by BullMQ for job queues
# Local:      redis://localhost:6379
# Docker:     redis://dragonfly:6379
# Production: rediss://<user>:<pass>@your-dragonfly-host:6380
DRAGONFLY_URL="redis://localhost:6379"
REDIS_URL="redis://localhost:6379"   # fallback if DRAGONFLY_URL is not set

# Optional external Python feed engine
FEED_SERVICE_ENABLED="false"
FEED_SERVICE_URL="localhost:50051"
FEED_SERVICE_TIMEOUT_MS="250"
FEED_SERVICE_HOST="0.0.0.0"
FEED_SERVICE_PORT="50051"

# Worker
WORKER_CONCURRENCY=2
FFMPEG_PATH="/usr/bin/ffmpeg"
