# ─────────────────────────────────────────────────────────────────
# PRODUCTION — fill in values then run: bun run env:encrypt:prod
# ─────────────────────────────────────────────────────────────────
DATABASE_URL="mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/podkaap?retryWrites=true&w=majority"
JWT_SECRET="production-secret-change-me"
PORT=3000
NODE_ENV="production"

# DragonflyDB / Redis (production instance)
DRAGONFLY_URL="rediss://<user>:<password>@<prod-dragonfly-host>:6380"
REDIS_URL="rediss://<user>:<password>@<prod-dragonfly-host>:6380"

# Storage
STORAGE_PROVIDER="cloudinary"
CLOUDINARY_URL=""
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# S3-compatible
S3_ENDPOINT=""
S3_BUCKET="podkaap-production"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_REGION="ap-southeast-1"

# Worker
WORKER_CONCURRENCY=8
FFMPEG_PATH="/usr/bin/ffmpeg"
