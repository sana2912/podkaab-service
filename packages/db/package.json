{
  "name": "@podkaap/db",
  "version": "0.1.0",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "db:push": "prisma db push --config ./prisma.config.ts",
    "db:migrate": "prisma migrate dev --config ./prisma.config.ts",
    "db:migrate:deploy": "prisma migrate deploy --config ./prisma.config.ts",
    "db:seed": "prisma db seed --config ./prisma.config.ts",
    "db:generate": "prisma generate --config ./prisma.config.ts",
    "db:studio": "prisma studio --config ./prisma.config.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0"
  },
  "devDependencies": {
    "@types/pg": "^8.20.0",
    "pg": "^8.20.0",
    "prisma": "^7.6.0",
    "typescript": "^6.0.2"
  }
}
